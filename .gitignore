# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Test / coverage
coverage/

# Tool cache (portable JDK, cmdline-tools downloads)
.sublime/

# Sandbox: track critical source of test apps, but never heavy/generated output.
# (Each test app's own .gitignore also excludes node_modules, /android, .expo, etc.)
**/node_modules/
sandbox/**/android/
sandbox/**/ios/
sandbox/**/.expo/
sandbox/**/.gradle/
sandbox/**/*.apk
sandbox/**/*.aab
**/local.properties

# Logs
*.log
npm-debug.log*

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Env
.env
.env.local
