    "@testing-library/react": "^16.0.1",
    "@types/node": "^22",
    "@types/react": "^18.3.12",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-native": "^0.76.1",
